# Copiar este archivo como .env y completar las API keys
# cp .env.example .env

# VirusTotal API Key
# Obtener en: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key
# Obtener en: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ThreatFox API Key (opcional)
# Obtener en: https://threatfox.abuse.ch/api/
THREATFOX_API_KEY=your_threatfox_api_key_here
